# Backpacker Backend — salin ke .env dan isi nilai sebenarnya.
# JANGAN commit file .env ke git.

# dev | prod
SPRING_PROFILES_ACTIVE=dev

# MySQL (application-dev.yml / application-prod.yml)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iwip_manajemen
DB_USERNAME=iwip
DB_PASSWORD=ganti-password-kuat

# JWT — WAJIB ganti di production (min. 32 karakter)
JWT_SECRET=ganti-dengan-openssl-rand-base64-48

# Redis (captcha + session token)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=1

# Upload path untuk gambar chat / profil
IWIP_UPLOAD_PATH=/home/nitro/iwip/uploadPath

# Flutter web build — agar mobile dilayani di http://host:8080/app/
# MOBILE_WEB_PATH=/path/to/report-app/build/web

# CORS — dev: * ; production: https://admin.domain.com,https://app.domain.com
CORS_ALLOWED_ORIGINS=*
